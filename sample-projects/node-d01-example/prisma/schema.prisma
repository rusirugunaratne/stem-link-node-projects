// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Movie {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  genre       String
  releaseYear Int
  createdAt   DateTime @default(now())
}
